{
  "manifest_version": 3,
  "name": "PromptBin",
  "version": "0.3.1",
  "description": "Store local text shortcuts and expand them in text fields across the web.",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "promptbin.png",
    "32": "promptbin.png",
    "48": "promptbin.png",
    "128": "promptbin.png"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "PromptBin",
    "default_icon": {
      "16": "promptbin.png",
      "32": "promptbin.png"
    }
  },
  "options_page": "ui/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ]
}
